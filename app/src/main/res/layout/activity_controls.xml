<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@color/background_dark">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:gravity="center_vertical"
             android:orientation="horizontal">

            <ImageView
                 android:layout_height="32dp"
                 android:layout_width="32dp"
                 android:src="@drawable/ic_controls"
                 android:tint="@color/icon_tint" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:textSize="22sp"
                 android:textColor="@android:color/white"
                 android:layout_marginStart="12dp"
                 android:layout_weight="1"
                 android:text="@string/controls_title"
                 android:textStyle="bold" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:textSize="14sp"
                 android:textColor="@android:color/darker_gray"
                 android:text="@string/app_name" />

        </LinearLayout>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:layout_marginBottom="12dp"
             android:textSize="18sp"
             android:textColor="@android:color/white"
             android:text="@string/touch_controls"
             android:textStyle="bold" />

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="horizontal">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textSize="16sp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:text="@string/enable_touch_controls" />

                    <Switch
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:id="@+id/switch_touch_controls" />

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="horizontal">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textSize="16sp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:text="@string/vibration" />

                    <Switch
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:id="@+id/switch_vibration" />

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="horizontal">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textSize="16sp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:text="@string/pressure_sensitivity" />

                    <Switch
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:id="@+id/switch_pressure_sensitivity" />

                </LinearLayout>

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="8dp"
                     android:textSize="14sp"
                     android:textColor="@android:color/white"
                     android:text="@string/control_size" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:gravity="center_vertical"
                     android:orientation="horizontal">

                    <SeekBar
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:max="100"
                         android:progress="70"
                         android:layout_weight="1"
                         android:id="@+id/seek_bar_touch_size" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="50dp"
                         android:gravity="end"
                         android:textColor="@android:color/white"
                         android:id="@+id/text_touch_size_value"
                         android:text="70%" />

                </LinearLayout>

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="8dp"
                     android:textSize="14sp"
                     android:textColor="@android:color/white"
                     android:text="@string/control_opacity" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:gravity="center_vertical"
                     android:orientation="horizontal">

                    <SeekBar
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:max="100"
                         android:progress="80"
                         android:layout_weight="1"
                         android:id="@+id/seek_bar_touch_opacity" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="50dp"
                         android:gravity="end"
                         android:textColor="@android:color/white"
                         android:id="@+id/text_touch_opacity_value"
                         android:text="80%" />

                </LinearLayout>

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="8dp"
                     android:textSize="14sp"
                     android:textColor="@android:color/white"
                     android:text="@string/control_layout" />

                <RadioGroup
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="horizontal"
                     android:id="@+id/radio_group_layout">

                    <RadioButton
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:id="@+id/radio_layout_classic"
                         android:text="@string/layout_classic" />

                    <RadioButton
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:id="@+id/radio_layout_modern"
                         android:text="@string/layout_modern" />

                    <RadioButton
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:id="@+id/radio_layout_minimal"
                         android:text="@string/layout_minimal" />

                </RadioGroup>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:layout_marginEnd="8dp"
                         app:cornerRadius="8dp"
                         android:backgroundTint="@color/accent_orange"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:id="@+id/button_customize_layout"
                         android:text="@string/customize_layout" />

                    <com.google.android.material.button.MaterialButton
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         app:cornerRadius="8dp"
                         android:backgroundTint="@android:color/holo_red_dark"
                         android:textColor="@android:color/white"
                         android:layout_marginStart="8dp"
                         android:layout_weight="1"
                         android:id="@+id/button_reset_touch"
                         android:text="@string/reset" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:layout_marginBottom="8dp"
             android:textSize="14sp"
             android:textColor="@android:color/white"
             android:text="@string/preview"
             android:textStyle="bold" />

        <FrameLayout
             android:layout_height="200dp"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:visibility="visible"
             android:background="#1A1A1A"
             android:id="@+id/frame_preview">

        </FrameLayout>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:layout_marginBottom="12dp"
             android:textSize="18sp"
             android:textColor="@android:color/white"
             android:text="@string/gamepad_mapping"
             android:textStyle="bold" />

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="horizontal">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:textSize="16sp"
                         android:textColor="@android:color/white"
                         android:layout_weight="1"
                         android:text="@string/enable_gamepad" />

                    <Switch
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:id="@+id/switch_gamepad_support" />

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     android:orientation="vertical"
                     android:id="@+id/layout_gamepad_info">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:layout_marginBottom="8dp"
                         android:textSize="14sp"
                         android:textColor="@android:color/white"
                         android:text="@string/gamepad_type" />

                    <RadioGroup
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="16dp"
                         android:orientation="horizontal"
                         android:id="@+id/radio_group_gamepad_type">

                        <RadioButton
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:textColor="@android:color/white"
                             android:layout_weight="1"
                             android:id="@+id/radio_gamepad_xbox"
                             android:text="@string/xbox" />

                        <RadioButton
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:textColor="@android:color/white"
                             android:layout_weight="1"
                             android:id="@+id/radio_gamepad_playstation"
                             android:text="@string/playstation" />

                        <RadioButton
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:textColor="@android:color/white"
                             android:layout_weight="1"
                             android:id="@+id/radio_gamepad_generic"
                             android:text="@string/generic" />

                    </RadioGroup>

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="16dp"
                         android:gravity="center"
                         android:textSize="13sp"
                         android:textColor="@android:color/holo_orange_light"
                         android:id="@+id/text_gamepad_status"
                         android:text="@string/no_mapping" />

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:layout_marginEnd="8dp"
                             app:cornerRadius="8dp"
                             android:backgroundTint="@color/primary_blue"
                             android:textColor="@android:color/white"
                             android:layout_weight="1"
                             android:id="@+id/button_map_keys"
                             android:text="@string/map_keys" />

                        <com.google.android.material.button.MaterialButton
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             app:cornerRadius="8dp"
                             android:backgroundTint="@android:color/holo_red_dark"
                             android:textColor="@android:color/white"
                             android:layout_marginStart="8dp"
                             android:layout_weight="1"
                             android:id="@+id/button_reset_mapping"
                             android:text="@string/reset_mapping" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>