<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@color/background_dark"
     android:padding="16dp"
     android:orientation="vertical">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="24dp"
         android:gravity="center_vertical"
         android:orientation="horizontal">

        <ImageView
             android:layout_height="32dp"
             android:layout_width="32dp"
             android:src="@drawable/ic_firmware"
             android:tint="@color/icon_tint" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="0dp"
             android:textSize="22sp"
             android:textColor="@android:color/white"
             android:layout_marginStart="12dp"
             android:layout_weight="1"
             android:text="@string/firmware_title"
             android:textStyle="bold" />

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textSize="14sp"
             android:textColor="@android:color/darker_gray"
             android:text="@string/app_name" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="16dp"
         app:cardElevation="4dp"
         app:cardBackgroundColor="@color/card_background"
         app:cardCornerRadius="12dp">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="16dp"
             android:orientation="vertical">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="8dp"
                 android:textSize="14sp"
                 android:textColor="@android:color/white"
                 android:text="@string/current_firmware"
                 android:textStyle="bold" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="4dp"
                 android:textSize="16sp"
                 android:textColor="@android:color/holo_red_dark"
                 android:id="@+id/text_view_current_firmware"
                 android:text="@string/no_firmware" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:textSize="13sp"
                 android:textColor="@android:color/holo_orange_dark"
                 android:id="@+id/text_view_firmware_status"
                 android:text="@string/firmware_required" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="16dp"
         app:cardElevation="4dp"
         app:cardBackgroundColor="@color/card_background"
         app:cardCornerRadius="12dp">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="16dp"
             android:orientation="vertical">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:layout_marginBottom="12dp"
                 android:textSize="14sp"
                 android:textColor="@android:color/white"
                 android:text="@string/select_firmware"
                 android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 app:icon="@drawable/ic_folder"
                 android:layout_marginBottom="12dp"
                 app:cornerRadius="8dp"
                 android:backgroundTint="@color/primary_blue"
                 app:iconTint="@android:color/white"
                 android:textColor="@android:color/white"
                 android:id="@+id/button_select_firmware"
                 android:text="@string/browse_firmware" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:gravity="center"
                 android:textSize="12sp"
                 android:textColor="@android:color/darker_gray"
                 android:id="@+id/text_view_firmware_path"
                 android:text="@string/no_firmware_selected" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginBottom="16dp"
         app:cardElevation="4dp"
         app:cardBackgroundColor="@color/card_background"
         app:cardCornerRadius="12dp">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="16dp"
             android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 app:icon="@drawable/ic_verify"
                 android:layout_marginBottom="16dp"
                 app:cornerRadius="8dp"
                 android:backgroundTint="@color/accent_orange"
                 app:iconTint="@android:color/white"
                 android:textColor="@android:color/white"
                 android:enabled="false"
                 android:id="@+id/button_verify_firmware"
                 android:text="@string/verify_firmware" />

            <CheckBox
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="16dp"
                 android:textColor="@android:color/white"
                 android:id="@+id/check_box_confirm_install"
                 android:text="@string/confirm_firmware_install" />

            <com.google.android.material.button.MaterialButton
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 app:icon="@drawable/ic_install"
                 app:cornerRadius="8dp"
                 android:backgroundTint="@android:color/holo_green_dark"
                 app:iconTint="@android:color/white"
                 android:textColor="@android:color/white"
                 android:enabled="false"
                 android:id="@+id/button_install_firmware"
                 android:text="@string/install_firmware" />

            <ProgressBar
                 android:layout_height="4dp"
                 android:layout_width="match_parent"
                 android:visibility="gone"
                 style="?android:attr/progressBarStyleHorizontal"
                 android:layout_marginTop="16dp"
                 android:id="@+id/progress_bar_firmware" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         app:cardElevation="2dp"
         app:cardBackgroundColor="#2C2C2C"
         app:cardCornerRadius="8dp">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="12dp"
             android:textSize="11sp"
             android:textColor="@android:color/darker_gray"
             android:text="@string/firmware_info_text" />

    </androidx.cardview.widget.CardView>

</LinearLayout>