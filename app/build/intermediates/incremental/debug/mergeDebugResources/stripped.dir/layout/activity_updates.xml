<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@color/background_dark">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:gravity="center_vertical"
             android:orientation="horizontal">

            <ImageView
                 android:layout_height="32dp"
                 android:layout_width="32dp"
                 android:src="@drawable/ic_updates"
                 android:tint="@color/icon_tint" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:textSize="22sp"
                 android:textColor="@android:color/white"
                 android:layout_marginStart="12dp"
                 android:layout_weight="1"
                 android:text="@string/updates_title"
                 android:textStyle="bold" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:textSize="14sp"
                 android:textColor="@android:color/darker_gray"
                 android:text="@string/app_name" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="8dp"
                     android:textSize="16sp"
                     android:textColor="@android:color/white"
                     android:id="@+id/text_view_current_version"
                     android:text="@string/loading" />

                <View
                     android:layout_height="1dp"
                     android:layout_width="match_parent"
                     android:layout_marginVertical="8dp"
                     android:background="#333333" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textColor="@android:color/holo_orange_light"
                     android:layout_marginTop="8dp"
                     android:id="@+id/text_view_latest_version"
                     android:text="@string/unknown" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="16dp"
                     android:textSize="14sp"
                     android:textColor="@android:color/darker_gray"
                     android:id="@+id/text_view_update_status"
                     android:text="@string/not_checked" />

                <com.google.android.material.button.MaterialButton
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     app:icon="@drawable/ic_refresh"
                     app:cornerRadius="8dp"
                     android:backgroundTint="@color/primary_blue"
                     app:iconTint="@android:color/white"
                     android:textColor="@android:color/white"
                     android:id="@+id/button_check_updates"
                     android:text="@string/check_for_updates" />

                <ProgressBar
                     android:layout_height="4dp"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     style="?android:attr/progressBarStyleHorizontal"
                     android:layout_marginTop="16dp"
                     android:id="@+id/progress_bar" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:layout_marginBottom="12dp"
                     android:textSize="16sp"
                     android:textColor="@android:color/white"
                     android:text="@string/changelog"
                     android:textStyle="bold" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:textSize="14sp"
                     android:textColor="@android:color/darker_gray"
                     android:lineSpacingExtra="4dp"
                     android:id="@+id/text_view_changelog"
                     android:text="@string/no_changelog" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="4dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     app:icon="@drawable/ic_download"
                     android:layout_marginBottom="12dp"
                     app:cornerRadius="8dp"
                     android:backgroundTint="@color/accent_orange"
                     app:iconTint="@android:color/white"
                     android:textColor="@android:color/white"
                     android:enabled="false"
                     android:id="@+id/button_download_update"
                     android:text="@string/download_update" />

                <com.google.android.material.button.MaterialButton
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     app:icon="@drawable/ic_install"
                     android:layout_marginBottom="12dp"
                     app:cornerRadius="8dp"
                     android:backgroundTint="@android:color/holo_green_dark"
                     app:iconTint="@android:color/white"
                     android:textColor="@android:color/white"
                     android:enabled="false"
                     android:id="@+id/button_install_update"
                     android:text="@string/install_update" />

                <ProgressBar
                     android:layout_height="4dp"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     style="?android:attr/progressBarStyleHorizontal"
                     android:id="@+id/progress_bar_download" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             app:cardElevation="2dp"
             app:cardBackgroundColor="#2C2C2C"
             app:cardCornerRadius="8dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="12dp"
                 android:textSize="11sp"
                 android:textColor="@android:color/darker_gray"
                 android:text="@string/update_info_text" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>