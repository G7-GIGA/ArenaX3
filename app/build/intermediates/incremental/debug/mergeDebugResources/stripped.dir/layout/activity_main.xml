<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="@android:color/black">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical">

        <ImageView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:adjustViewBounds="true"
             android:src="@drawable/ic_arena_logo"
             android:contentDescription="@string/arena_logo" />

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_games">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_games"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="Games"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="Launch and manage ArenaX3 games" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_firmware">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_firmware"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="Firmware"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="Check and update device firmware" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_controls">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_controls"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="Controls"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="Configure input and touch controls" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_settings">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_settings"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="Settings"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="ArenaX3 preferences and options" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_updates">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_updates"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="Updates"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="Check for new content and patches" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             app:cardElevation="8dp"
             app:cardBackgroundColor="@color/card_background"
             app:cardCornerRadius="12dp"
             android:id="@+id/card_about">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="20dp"
                 android:orientation="horizontal">

                <ImageView
                     android:layout_height="48dp"
                     android:layout_width="48dp"
                     android:src="@drawable/ic_about"
                     android:tint="@color/icon_tint" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="0dp"
                     android:orientation="vertical"
                     android:layout_marginStart="16dp"
                     android:layout_weight="1">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="18sp"
                         android:textColor="@android:color/white"
                         android:text="About"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:textColor="@android:color/darker_gray"
                         android:text="ArenaX3 version and credits" />

                </LinearLayout>

                <ImageView
                     android:layout_height="24dp"
                     android:layout_width="24dp"
                     android:src="@drawable/ic_chevron_right"
                     android:tint="@color/icon_tint" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>